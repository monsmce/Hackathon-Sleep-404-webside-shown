                new("Floor plan", "/floor-plan")
            ])
    ];

    private void ToggleMenu()
    {
        _isMenuOpen = !_isMenuOpen;
    }

    private void CloseMenu()
    {
        _isMenuOpen = false;
    }

    private void ToggleSection(string title)
    {
        _expandedSection = _expandedSection == title ? string.Empty : title;
    }

    private bool IsSectionOpen(string title)
    {
        if (!string.IsNullOrWhiteSpace(_menuSearch))
        {
            return SectionMatches(title) || GetVisibleLinks(_menuSections.First(section => section.Title == title)).Count > 0;
        }

        return _expandedSection == title;
    }

    private bool SectionMatches(string title) =>
        string.IsNullOrWhiteSpace(_menuSearch) ||
        title.Contains(_menuSearch, StringComparison.OrdinalIgnoreCase);

    private IReadOnlyList<MenuLink> GetVisibleLinks(MenuSection section)
    {
        if (string.IsNullOrWhiteSpace(_menuSearch))
        {
            return section.Links;
        }

        return section.Links
            .Where(link => link.Label.Contains(_menuSearch, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private sealed record MenuSection(string Title, IReadOnlyList<MenuLink> Links);

    private sealed record MenuLink(string Label, string Href);
}
