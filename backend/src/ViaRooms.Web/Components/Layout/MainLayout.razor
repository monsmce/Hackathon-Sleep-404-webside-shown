@inherits LayoutComponentBase

<header class="header">
    <div class="container header-inner">
        <NavLink href="/" Match="NavLinkMatch.All" class="logo" @onclick="CloseMenu">
            <img src="/images/logo.gif" alt="MyVIA logo" />
        </NavLink>

        <nav class="nav desktop-nav" aria-label="Primary">
            <a href="/#news" class="nav-link" @onclick="CloseMenu">News</a>
            <a href="/map" class="nav-link" @onclick="CloseMenu">Map view</a>
            <a href="/floor-plan" class="nav-link" @onclick="CloseMenu">Floor plan</a>
            <a href="/availability" class="nav-link" @onclick="CloseMenu">Availability overview</a>
            <button id="menuBtn" type="button" class="nav-link menu-trigger" @onclick="ToggleMenu" aria-expanded="@_isMenuOpen">
                Menu &#9776;
            </button>
        </nav>
    </div>
</header>

<div id="overlay" class="@(_isMenuOpen ? "active" : string.Empty)" @onclick="CloseMenu"></div>

<aside id="sideMenu" class="side-menu @(_isMenuOpen ? "active" : string.Empty)" aria-hidden="@(!_isMenuOpen)">
    <div class="menu-header">
        <NavLink href="/" Match="NavLinkMatch.All" class="logo" @onclick="CloseMenu">
            <img src="/images/logo.gif" alt="MyVIA logo" />
        </NavLink>
        <button id="closeMenu" type="button" class="menu-close" @onclick="CloseMenu">x</button>
    </div>

    <input class="menu-search"
           @bind="_menuSearch"
           @bind:event="oninput"
           placeholder="Try searching!" />

    @foreach (var menuSection in _menuSections)
    {
        var visibleLinks = GetVisibleLinks(menuSection);
        var showSection = SectionMatches(menuSection.Title) || visibleLinks.Count > 0;

        if (!showSection)
        {
            continue;
        }

        <div class="menu-section @(IsSectionOpen(menuSection.Title) ? "active" : string.Empty)"
             @onclick="() => ToggleSection(menuSection.Title)">
            <div class="menu-title">
                <span>@menuSection.Title</span>
                <span>@(IsSectionOpen(menuSection.Title) ? "-" : "+")</span>
            </div>

            @if (IsSectionOpen(menuSection.Title))
            {
                <div class="submenu">
                    @foreach (var link in visibleLinks)
                    {
                        <a href="@link.Href" @onclick="CloseMenu">@link.Label</a>
                    }
                </div>
            }
        </div>
    }
</aside>

<main class="page-shell">
    @Body
</main>

<nav class="mobile-nav" aria-label="Mobile">
    <NavLink href="/" Match="NavLinkMatch.All" class="mobile-nav-item" ActiveClass="active" @onclick="CloseMenu">MyVIA</NavLink>
    <a href="/#news" class="mobile-nav-item" @onclick="CloseMenu">News</a>
    <a href="/map" class="mobile-nav-item" @onclick="CloseMenu">Map</a>
    <a href="/floor-plan" class="mobile-nav-item" @onclick="CloseMenu">Floor plan</a>
    <a href="/availability" class="mobile-nav-item" @onclick="CloseMenu">Overview</a>
    <button id="menuBtnMobile" type="button" class="mobile-nav-item" @onclick="ToggleMenu">Menu &#9776;</button>
</nav>

<script>
    (() => {
        const overlay = document.getElementById("overlay");
        const sideMenu = document.getElementById("sideMenu");
        const menuBtn = document.getElementById("menuBtn");
        const menuBtnMobile = document.getElementById("menuBtnMobile");
        const closeMenu = document.getElementById("closeMenu");

        const openMenu = () => {
            sideMenu?.classList.add("active");
            overlay?.classList.add("active");
        };

        const hideMenu = () => {
            sideMenu?.classList.remove("active");
            overlay?.classList.remove("active");
        };

        menuBtn?.addEventListener("click", openMenu);
        menuBtnMobile?.addEventListener("click", openMenu);
        closeMenu?.addEventListener("click", hideMenu);
        overlay?.addEventListener("click", hideMenu);

        document.querySelectorAll(".menu-section").forEach(section => {
            section.addEventListener("click", (e) => {
                const target = e.target;
                // Don't collapse when clicking a link inside the submenu
                if (target && target.closest && target.closest("a")) return;

                const isActive = section.classList.contains("active");
                document.querySelectorAll(".menu-section").forEach(s => s.classList.remove("active"));
                if (!isActive) section.classList.add("active");
            });
        });
    })();
</script>

