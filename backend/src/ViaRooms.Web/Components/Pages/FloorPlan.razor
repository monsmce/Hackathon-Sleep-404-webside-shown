@page "/floor-plan"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.SignalR.Client
@using System.Text.Json
@inject RoomApiService RoomService
@inject IConfiguration Config
@inject IWebHostEnvironment Env
@implements IAsyncDisposable

<PageTitle>MyVIA | Floor Plan</PageTitle>

<section class="page-intro">
    <div class="container page-intro-inner">
        <div>
            <p class="eyebrow">my via | floor plan</p>
            <h1>Live room markers on the building plans.</h1>
            <p>Use the floor plans when you need exact room placement alongside availability.</p>
        </div>
        <p class="last-updated">Last updated: @(_rooms is null ? "--" : _lastUpdated.ToLocalTime().ToString("HH:mm:ss"))</p>
    </div>
</section>

<section class="page-panel">
    <div class="container">
        <div class="legend">
            <div class="legend-item">
                <span class="legend-dot available"></span>
                <span>Available</span>
            </div>
            <div class="legend-item">
                <span class="legend-dot occupied"></span>
                <span>Occupied</span>
            </div>
            <div class="legend-item">
                <span class="legend-dot unknown"></span>
                <span>Classroom</span>
            </div>
        </div>

        @if (_floorData is null || _rooms is null)
        {
            <p class="section-empty">Loading floor plans...</p>
        }
        else
        {
            @foreach (var floor in _floorData)
            {
                <div class="floor-plan-section">
                    <div class="panel-heading">
                        <div>
                            <p class="eyebrow">Interactive floor</p>
                            <h2>@floor.Name</h2>
                        </div>
                        <p class="panel-note">@floor.Rooms.Count rooms shown</p>
                    </div>

                    <div class="floor-plan-container">
                        <img class="floor-plan-image" src="@floor.Src" alt="@floor.Name" />

                        @foreach (var room in floor.Rooms)
                        {
                            var liveRoom = _rooms.FirstOrDefault(item => string.Equals(item.RoomId, room.Name, StringComparison.OrdinalIgnoreCase));
                            var statusCss = GetStatusCss(liveRoom?.Status);
                            var title = $"{room.Name} - {statusCss}";

                            <div class="room-dot" style="left: @(room.X)px; top: @(room.Y)px;">
                                <div class="room-dot__marker @statusCss" title="@title"></div>
                                <span class="room-dot__label">@room.Name</span>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>
</section>

@code {
    private List<StudyRoom>? _rooms;
    private List<FloorPlanData>? _floorData;
    private DateTime _lastUpdated = DateTime.UtcNow;
    private HubConnection? _hubConnection;

    public class RoomData
    {
        public long Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string Type { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public double X { get; set; }
        public double Y { get; set; }
    }

    public class FloorPlanData
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string Src { get; set; } = string.Empty;
        public List<RoomData> Rooms { get; set; } = [];
    }

    protected override async Task OnInitializedAsync()
    {
        var jsonPath = System.IO.Path.Combine(Env.WebRootPath, "floor_plan_data.json");
        if (System.IO.File.Exists(jsonPath))
        {
            var json = await System.IO.File.ReadAllTextAsync(jsonPath);
            _floorData = JsonSerializer.Deserialize<List<FloorPlanData>>(json, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
        }

        await LoadRoomsAsync();

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Config["ApiBaseUrl"] + "/roomhub")
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On("RoomUpdated", async () =>
        {
            await LoadRoomsAsync();
            await InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();
    }

    private async Task LoadRoomsAsync()
    {
        _rooms = await RoomService.GetAllRoomsAsync() ?? [];
        _lastUpdated = DateTime.UtcNow;
    }

    private static string GetStatusCss(RoomStatus? status) => status switch
    {
        RoomStatus.Available => "available",
        RoomStatus.Occupied => "occupied",
        _ => "unknown"
    };

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}
