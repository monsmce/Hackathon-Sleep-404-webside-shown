@page "/floor-plan"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.SignalR.Client
@using System.Text.Json
@using Microsoft.AspNetCore.Hosting
@inject RoomApiService RoomService
@inject IConfiguration Config
@inject IWebHostEnvironment Env
@implements IAsyncDisposable

<section class="page-intro page-intro--inline">
    <div class="container">
        <div class="page-intro-inner">
            <div>
                <p class="eyebrow">Maps</p>
                <h1>Floor plan</h1>
                <p>See live room markers on each floor. Dots update automatically as status changes.</p>
            </div>
            <div class="intro-meta">
                <p class="last-updated">Last updated: @_lastUpdated.ToLocalTime().ToString("HH:mm:ss")</p>
            </div>
        </div>

        <div class="legend">
            <div class="legend-item">
                <span class="legend-dot" style="background: var(--success);"></span>
                <span>Available</span>
            </div>
            <div class="legend-item">
                <span class="legend-dot" style="background: var(--danger);"></span>
                <span>Occupied</span>
            </div>
            <div class="legend-item">
                <span class="legend-dot" style="background: #8d8a85;"></span>
                <span>Classroom</span>
            </div>
        </div>
    </div>
</section>

@if (_floorData is null || _rooms is null)
{
    <div class="container">
        <p class="section-empty">Loading floor plans...</p>
    </div>
}
else
{
    <div class="container">
        @foreach (var floor in _floorData)
        {
            var available = CountStatus(floor.Rooms, RoomStatus.Available);
            var occupied = CountStatus(floor.Rooms, RoomStatus.Occupied);
            var total = floor.Rooms.Count;

            <section class="floor-plan-section">
                <div class="floor-plan-header">
                    <div>
                        <span class="pill">Floor</span>
                        <h3>@floor.Name</h3>
                        <p class="floor-plan-sub">@total rooms mapped</p>
                    </div>
                    <div class="floor-plan-stats">
                        <span class="status-pill available">Available @available</span>
                        <span class="status-pill occupied">Occupied @occupied</span>
                        <span class="status-pill neutral">Classroom @(total - available - occupied)</span>
                    </div>
                </div>

                <div class="floor-plan-card">
                    <div class="floor-plan-container">
                        <img src="@floor.Src" alt="@floor.Name" class="floor-plan-image" />

                        @foreach (var room in floor.Rooms)
                        {
                            var liveRoom = _rooms?.FirstOrDefault(r => string.Equals(r.RoomId, room.Name, StringComparison.OrdinalIgnoreCase));
                            var statusCss = liveRoom?.Status.ToString().ToLower() ?? "classroom";

                            var dotColor = statusCss == "available"
                                ? "lightgreen"
                                : statusCss == "occupied"
                                    ? "#ff4d4d"
                                    : "gray";

                            <div class="room-dot"
                                 style="left: @(room.X)%; top: @(room.Y)%;"
                                 title="@room.Name - @statusCss">
                                <div class="room-dot__marker" style="background-color: @dotColor;"></div>
                                <div class="room-dot__label">@room.Name</div>
                            </div>
                        }
                    </div>
                </div>
            </section>
        }
    </div>
}

@code {
    private List<StudyRoom>? _rooms;
    private List<FloorPlanData>? _floorData;
    private DateTime _lastUpdated = DateTime.UtcNow;
    private HubConnection? _hubConnection;

    public class RoomData
    {
        public long Id { get; set; }
        public string Name { get; set; } = "";
        public string Type { get; set; } = "";
        public string Status { get; set; } = "";
        public double X { get; set; }
        public double Y { get; set; }
    }

    public class FloorPlanData
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Src { get; set; } = "";
        public List<RoomData> Rooms { get; set; } = new();
    }

    protected override async Task OnInitializedAsync()
    {
        var jsonPath = System.IO.Path.Combine(Env.WebRootPath, "floor_plan_PERCENTAGE.json");
        if (System.IO.File.Exists(jsonPath))
        {
            var json = await System.IO.File.ReadAllTextAsync(jsonPath);
            _floorData = JsonSerializer.Deserialize<List<FloorPlanData>>(json, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
        }

        await LoadRoomsAsync();

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Config["ApiBaseUrl"] + "/roomhub")
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On("RoomUpdated", async () =>
        {
            await LoadRoomsAsync();
            await InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();
    }

    private async Task LoadRoomsAsync()
    {
        _rooms = await RoomService.GetAllRoomsAsync() ?? [];
        _lastUpdated = DateTime.UtcNow;
    }

    private int CountStatus(IEnumerable<RoomData> rooms, RoomStatus status) =>
        rooms.Count(room =>
        {
            var liveRoom = _rooms?.FirstOrDefault(r => string.Equals(r.RoomId, room.Name, StringComparison.OrdinalIgnoreCase));
            return liveRoom?.Status == status;
        });

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
            await _hubConnection.DisposeAsync();
    }
}
